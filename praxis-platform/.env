# Praxis Platform Environment Configuration
# Generated: 2026-03-15

# ===========================================
# ENVIRONMENT
# ===========================================
NODE_ENV=development
PORT=3000

# ===========================================
# AGENT ZERO COMMUNICATION
# ===========================================
AGENT_ZERO_URL=http://agent-zero:80
AGENT_ZERO_API_KEY=

# ===========================================
# INSFORGE CLOUD MCP
# ===========================================
INSFORGE_MCP_URL=cloud-mcp.insforge.dev
INSFORGE_MCP_TOKEN=
INSFORGE_PROJECT_ID=

# ===========================================
# AGENTMAIL.TO - EMAIL PROCESSING
# ===========================================
AGENTMAIL_API_KEY=
AGENTMAIL_TO=cca@agentmail.to
AGENTMAIL_WEBSOCKET_URL=wss://ws.agentmail.to/v0
AGENTMAIL_API_URL=https://api.agentmail.to/v0

# ===========================================
# LLM API PROVIDERS
# ===========================================

# Z.AI API (OpenAI-Compatible) - Primary
ZAI_API_KEY=
ZAI_BASE_URL=https://api.z.ai/api/coding/paas/v4
ZAI_MODEL=gpt-4

# xAI Grok API
XAI_API_KEY=
XAI_BASE_URL=https://api.x.ai/v1
XAI_MODEL=grok-2

# OpenRouter API
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# Qwen 3.5 Plus (Anthropic-Compatible)
ANTHROPIC_AUTH_TOKEN=
ANTHROPIC_BASE_URL=https://coding-intl.dashscope.aliyuncs.com/apps/anthropic
ANTHROPIC_MODEL=qwen3.5-plus

# Default LLM Provider (options: zai, xai, openrouter, qwen)
DEFAULT_LLM_PROVIDER=zai

# ===========================================
# WEB SEARCH & SCRAPING
# ===========================================

# Tavily Web Search
TAVILY_API_KEY=
TAVILY_MCP_URL=https://mcp.tavily.com/mcp/?tavilyApiKey=

# Firecrawl Web Scraping
FIRECRAWL_API_KEY=

# ===========================================
# MEMORY & LEARNING
# ===========================================

# Memo Advanced Memory
MEMO_API_KEY=

# ===========================================
# CODE EXECUTION
# ===========================================

# E2B Code Execution
E2B_API_KEY=

# ===========================================
# CARBON TRADING - BUSINESS SYSTEMS
# ===========================================

# Aspect Platform
ASPECT_API_KEY=
ASPECT_API_URL=https://api.aspect.carbon/v1

# Xero Accounting
XERO_API_KEY=
XERO_API_URL=https://api.xero.com/api.xro/2.0

# Monday.com Workflow
MONDAY_API_KEY=
MONDAY_API_URL=https://api.monday.com/v2
MONDAY_EXCEPTIONS_BOARD_ID=

# Planful Financial Planning
PLANFUL_API_KEY=
PLANFUL_API_URL=

# ===========================================
# CONTAINER CONFIGURATION
# ===========================================
CONTAINER_RUNTIME=docker
CONTAINER_IMAGE=praxis-agent:latest
MEMORY_LIMIT=512m
CPU_LIMIT=1

# ===========================================
# TASK SCHEDULING
# ===========================================
ENABLE_SCHEDULER=true
RECONCILE_SCHEDULE=0 8 * * *
REPORT_SCHEDULE_WEEKLY=0 9 * * 1
COMPLIANCE_CHECK_SCHEDULE=0 */6 * * *

# ===========================================
# LOGGING & MONITORING
# ===========================================
LOG_LEVEL=info
LOG_FORMAT=json
AUDIT_LOG_PATH=/data/logs/audit.log
API_TIMEOUT_MS=3000000

# ===========================================
# STORAGE PATHS
# ===========================================
MEMORY_PATH=/data/memory
GLOBAL_MEMORY_PATH=/data/global
CREDENTIALS_PATH=/data/credentials
STORAGE_PATH=/data/storage
