# Praxis Platform Environment Configuration

# Environment
NODE_ENV=development
PORT=3000

# Agent Zero Communication
AGENT_ZERO_URL=http://agent-zero:80
AGENT_ZERO_API_KEY=

# InsForge Cloud MCP
INSFORGE_MCP_URL=cloud-mcp.insforge.dev
INSFORGE_MCP_TOKEN=
INSFORGE_PROJECT_ID=

# AgentMail.to Integration
AGENTMAIL_API_KEY=am_live_xxxxx
AGENTMAIL_TO=cca@agentmail.to
AGENTMAIL_WEBSOCKET_URL=wss://ws.agentmail.to/v0
AGENTMAIL_API_URL=https://api.agentmail.to/v0

# Carbon Trading - Aspect Platform
ASPECT_API_KEY=
ASPECT_API_URL=https://api.aspect.carbon/v1

# Accounting - Xero
XERO_API_KEY=
XERO_API_URL=https://api.xero.com/api.xro/2.0

# Workflow - Monday.com
MONDAY_API_KEY=
MONDAY_API_URL=https://api.monday.com/v2
MONDAY_EXCEPTIONS_BOARD_ID=

# Financial Planning - Planful
PLANFUL_API_KEY=
PLANFUL_API_URL=

# Container Configuration
CONTAINER_RUNTIME=docker
CONTAINER_IMAGE=praxis-agent:latest
MEMORY_LIMIT=512m
CPU_LIMIT=1

# Task Scheduling
ENABLE_SCHEDULER=true
RECONCILE_SCHEDULE=0 8 * * *
REPORT_SCHEDULE_WEEKLY=0 9 * * 1
COMPLIANCE_CHECK_SCHEDULE=0 */6 * * *

# Logging
LOG_LEVEL=info
LOG_FORMAT=json
AUDIT_LOG_PATH=/data/logs/audit.log

# Memory & Storage
MEMORY_PATH=/data/memory
GLOBAL_MEMORY_PATH=/data/global
CREDENTIALS_PATH=/data/credentials
STORAGE_PATH=/data/storage

# Security
JWT_SECRET=
ENCRYPTION_KEY=
API_RATE_LIMIT=100
API_RATE_WINDOW=60000
