# Praxis Platform - Agent Worker Dockerfile
FROM node:22-alpine

WORKDIR /app

# Install dependencies
COPY package*.json ./
RUN npm ci --only=production

# Copy source code
COPY . .

# Build TypeScript
RUN npm run build

# Set default agent type
ENV AGENT_TYPE=email-processing

# Start application (agent mode)
CMD ["node", "dist/agent.js"]
