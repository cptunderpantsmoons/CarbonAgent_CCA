{
  "name": "praxis-platform",
  "version": "1.0.0",
  "description": "Praxis Email Agent - Autonomous email processing for carbon credit trading",
  "main": "src/index.ts",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "start": "node --loader tsx src/index.ts",
    "build": "tsc",
    "test": "vitest",
    "lint": "eslint src",
    "format": "prettier --write src"
  },
  "keywords": [
    "email",
