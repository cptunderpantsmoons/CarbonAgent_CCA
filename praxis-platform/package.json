    "carbon-trading",
    "automation",
    "nanoclaw"
  ],
  "author": "Praxis Carbon Team",
  "license": "MIT",
  "dependencies": {
    "@anthropic-ai/sdk": "^0.32.1",
    "ws": "^8.18.0",
    "node-fetch": "^3.3.2",
    "dotenv": "^16.4.7",
    "zod": "^3.24.1",
    "ioredis": "^5.4.2",
    "better-sqlite3": "^11.8.1",
    "node-cron": "^3.0.3"
  },
  "devDependencies": {
    "@types/node": "^22.13.10",
    "@types/ws": "^8.5.13",
    "@types/better-sqlite3": "^7.6.12",
    "@types/node-cron": "^3.0.11",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3",
    "vitest": "^3.0.7",
    "eslint": "^9.22.0",
    "prettier": "^3.5.3"
  },
  "engines": {
    "node": ">=20.0.0"
