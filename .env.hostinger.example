# Hostinger VPS Production Environment Configuration
# ===================================================
# Copy this file to .env.hostinger and fill in your values
# NEVER commit the actual .env.hostinger file to git!

# ===================================================
# CRITICAL: Change these for production!
# ===================================================

# Server Configuration
PORT=7130

# PostgreSQL Configuration
POSTGRES_USER=praxis_admin
POSTGRES_PASSWORD=CHANGE_THIS_SECURE_PASSWORD
POSTGRES_DB=praxis_agent_carbon

# Authentication - GENERATE A STRONG SECRET (min 32 characters)
# Use: openssl rand -hex 32
JWT_SECRET=CHANGE_THIS_SUPER_SECRET_KEY_MINIMUM_32_CHARACTERS

# Admin Account - CHANGE IMMEDIATELY AFTER DEPLOYMENT!
ADMIN_EMAIL=admin@yourdomain.com
ADMIN_PASSWORD=CHANGE_THIS_SECURE_ADMIN_PASSWORD

# Encryption key (can use same as JWT_SECRET if not provided)
ENCRYPTION_KEY=

# API Key (must start with ik_)
# Use: echo "ik_$(openssl rand -hex 16)"
ACCESS_API_KEY=ik_CHANGE_THIS_API_KEY_32_CHARS_MINIMUM

# ===================================================
# Domain Configuration (Update with your domain)
# ===================================================

# Replace with your actual domain or VPS IP
API_BASE_URL=http://your-vps-ip:7130
VITE_API_BASE_URL=http://your-vps-ip:7130

# Cloud API Host (Optional)
CLOUD_API_HOST=https://api.insforge.dev

# ===================================================
# Storage Configuration
# ===================================================

# For local storage (default on Hostinger VPS)
LOGS_DIR=/insforge-logs
STORAGE_DIR=/insforge-storage

# Max upload file size in bytes (default: 50MB)
MAX_FILE_SIZE=

# For S3/Wasabi storage (recommended for production)
# Leave empty to use local storage
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=
AWS_S3_BUCKET=

# S3-compatible storage (Wasabi, MinIO, etc.)
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_ENDPOINT_URL=

# ===================================================
# LLM Model API Keys
# ===================================================

# OpenRouter (for Claude, GPT-4, etc.) - Get from https://openrouter.ai/keys
OPENROUTER_API_KEY=

# ===================================================
# OAuth Configuration (Optional)
# Configure these if you want social login
# ===================================================

# Google OAuth - https://console.cloud.google.com/
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# GitHub OAuth - https://github.com/settings/developers
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Microsoft OAuth - https://portal.azure.com/
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=

# Discord OAuth - https://discord.com/developers/applications
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=

# LinkedIn OAuth - https://www.linkedin.com/developers/apps
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=

# X (Twitter) OAuth - https://developer.twitter.com/en/portal/dashboard
X_CLIENT_ID=
X_CLIENT_SECRET=

# Apple OAuth - https://developer.apple.com/account/resources/identifiers/list
APPLE_CLIENT_ID=
APPLE_CLIENT_SECRET=

# ===================================================
# Multi-tenant Cloud Configuration (Optional)
# Only needed if using cloud deployment features
# ===================================================

DEPLOYMENT_ID=
PROJECT_ID=
APP_KEY=

# ===================================================
# Deno Subhosting Configuration (Optional)
# For serverless edge functions
# ===================================================

DENO_SUBHOSTING_TOKEN=
DENO_SUBHOSTING_ORG_ID=

# ===================================================
# Swarm (NanoClaw) Configuration
# ===================================================

# Trigger word for the assistant
TRIGGER_WORD=@Andy

# Default Claude model
DEFAULT_MODEL=claude-opus-4-1-20250805

# Storage and Logs directories for Swarm
STORAGE_DIR=/swarm-storage
LOGS_DIR=/swarm-logs

# ===================================================
# Additional Settings
# ===================================================

# Branch (keep as local for Hostinger VPS deployment)
BRANCH=local

# Posthog Analytics (Optional - for development tracking)
VITE_PUBLIC_POSTHOG_KEY=

# ===================================================
# Deployment Notes for Hostinger VPS
# ===================================================
# 
# 1. Generate secure secrets before deploying:
#    - JWT_SECRET: openssl rand -hex 32
#    - Database Password: openssl rand -base64 24
#    - API Key: echo "ik_$(openssl rand -hex 16)"
#
# 2. Update API_BASE_URL and VITE_API_BASE_URL with:
#    - Your VPS IP address, or
#    - Your domain name
#
# 3. Configure firewall on Hostinger VPS:
#    - Allow ports: 22 (SSH), 50080 (WebUI), 7131 (Dashboard)
#    - Allow 80/443 if using reverse proxy with SSL
#
# 4. Deploy with:
#    docker compose -f docker-compose.unified.yml up -d
#
# 5. See HOSTINGER_DEPLOYMENT.md for complete guide
# ===================================================
