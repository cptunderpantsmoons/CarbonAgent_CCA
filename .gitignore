# ===================================================
# CarbonAgent - Global .gitignore
# Praxis Agent Carbon + InsForge + Swarm Platform
# ===================================================

# Sensitive Files - NEVER commit these
.env
.env.*.local
.env.local
*.pem
*.key
*.secret

# Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Runtime data
*.db
*.db-shm
*.db-wal
*.db-journal
pids/
*.pid
*.seed
*.pid.lock

# Directory for instrumented libs
coverage/

# Compiled files
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg

# Virtual environments
.venv/
venv/
ENV/
env/
.conda/

# IDE and Editor files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
.idea/
.vscode/
*.swp
*.swo
*~
.project
.classpath
.settings/
.cursor/
.windsurf/
.claude/

# Node.js
node_modules/
npm-debug.log
yarn-error.log
.npm
.eslintcache

# Deno
deno.lock
deno_dir/

# TypeScript
*.tsbuildinfo

# Test files
*.test.py
*.test.js
*.spec.js
__tests__/

# Obsolete directories (from Agent Zero migration)
memory/
knowledge/custom/
instruments/

# Agent runtime data
.agent/
agent_history.gif

# Temporary files
tmp/
temp/
.tmp/

# Docker volumes (local persistence)
postgres-data/
storage-data/
swarm-workspace/
swarm-workspace-test/

# Build artifacts
.ruff_cache/
.pytest_cache/
.mypy_cache/

# MCP configuration (may contain sensitive paths)
.mcp.json

# Better Auth generated files
better-auth/

# CLAUDE.md files (optional project context)
CLAUDE.md

# ===================================================
# Important: We DO track these for documentation
# ===================================================
# .env.example files ARE tracked
# .env.railway.example IS tracked
# .gitkeep files ARE tracked (to preserve empty directories)
